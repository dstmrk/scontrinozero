# ScontrinoZero — Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# PostgreSQL (transaction pooler — for app runtime)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# PostgreSQL (direct — for drizzle-kit migrations)
DATABASE_URL_DIRECT=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# =============================================================================
# Agenzia delle Entrate integration
# =============================================================================
# real = send to AdE (production only)
# mock = simulate responses (test/development)
ADE_MODE=mock

# =============================================================================
# Stripe
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# =============================================================================
# Resend (email)
# =============================================================================
RESEND_API_KEY=re_...
# Sender address — must use a domain verified on Resend
# Use a dedicated subdomain to isolate email reputation from the root domain
# Example: YourApp <noreply@mail.yourdomain.com>
FROM_EMAIL=YourApp <noreply@mail.yourdomain.com>

# =============================================================================
# Sentry
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=scontrinozero

# =============================================================================
# Encryption
# =============================================================================
# AES-256-GCM key (hex, 64 characters = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here
ENCRYPTION_KEY_VERSION=1

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=debug
# Salt used to hash client IPs in logs (rate limit, audit). Recommended in prod.
# LOG_HASH_SALT=

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production values for hostname routing (proxy.ts):
# NEXT_PUBLIC_APP_URL=https://app.scontrinozero.it
NEXT_PUBLIC_APP_HOSTNAME=app.scontrinozero.it
NEXT_PUBLIC_MARKETING_HOSTNAME=scontrinozero.it
# Runtime override of the hostname baked at build time. Used by self-hosted
# installs on a custom domain or by the sandbox container.
# Sandbox: APP_HOSTNAME=sandbox.scontrinozero.it
# APP_HOSTNAME=
# API subdomain — pass-through Bearer auth, no session cookie required.
# Dev: api-dev.scontrinozero.it | Sandbox: api-sandbox.scontrinozero.it
# Fallback hardcoded in proxy.ts: api.scontrinozero.it
NEXT_PUBLIC_API_HOSTNAME=api.scontrinozero.it

# =============================================================================
# Cloudflare Turnstile (CAPTCHA registrazione)
# =============================================================================
# Crea un sito su: Cloudflare Dashboard → Turnstile → Add Site
# Widget type: Managed — doc test keys: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Chiave segreta server-side (non esporre mai al client)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# =============================================================================
# Development / build
# =============================================================================
# Suppress @serwist/next informational warning about Turbopack (Next.js 16
# uses Turbopack by default; the service worker is still generated correctly).
SERWIST_SUPPRESS_TURBOPACK_WARNING=1

# =============================================================================
# CI / smoke test
# =============================================================================
# Skip running DB migrations on container start. Used by deploy smoke test
# to spin up the image without touching Supabase.
# SKIP_MIGRATIONS=1
# Assert that STRIPE_SECRET_KEY is a livemode key (sk_live_*). Set in
# production env only — fails fast at boot if a test key slips in.
# STRIPE_EXPECT_LIVEMODE=1
